# Telegram bot token for Alpha
ALPHA_BOT_TOKEN=123456:ABC-DEF...

# Optional: override Hugging Face Space id
ALPHA_SPACE_ID=magistrigusti/allod-alpha

# Optional: only needed if the Space becomes private
HF_TOKEN=hf_...

# Secret header that Telegram sends back to Vercel webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret

# Secret for one-time webhook registration endpoint
TELEGRAM_WEBHOOK_SETUP_TOKEN=replace-with-random-secret

# Optional: only used by src/openai.js for audio transcription / legacy OpenAI helpers
OPENAI_KEY=sk-proj-...

# Optional runtime port for local запуск
PORT=3000
