# Telegram bot token
ALPHA_BOT_TOKEN=123456:ABC-DEF...

# NVIDIA NIM API brain for Alpha
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_MODEL_FALLBACKS=meta/llama-3.1-8b-instruct,qwen/qwen2.5-7b-instruct,mistralai/mistral-7b-instruct-v0.3

# Optional local port for Express
PORT=3000

# Optional: how many messages Alpha keeps per chat in Telegram
ALPHA_CHAT_HISTORY_LIMIT=24

# Optional: per Alpha request settings
ALPHA_REQUEST_TIMEOUT_MS=25000
ALPHA_MAX_CONTEXT_MESSAGES=8
ALPHA_MAX_TOKENS=420
ALPHA_TEMPERATURE=0.35
ALPHA_TOP_P=0.9

# Optional: browser origins allowed to call /api/alpha
ALPHA_CORS_ORIGIN=*

# Optional webhook secrets for Vercel mode
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_WEBHOOK_SETUP_TOKEN=replace-with-random-secret
