# Telegram bot token
ALPHA_BOT_TOKEN=123456:ABC-DEF...

# Hugging Face Space id for Alpha
ALPHA_SPACE_ID=magistrigusti/allod-alpha

# Optional: only if the HF Space is private
HF_TOKEN=hf_...

# Optional: HF Space model provider. Keep local for Qwen in Space, or use nvidia for NVIDIA NIM API.
ALPHA_MODEL_PROVIDER=local
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=qwen/qwen2.5-7b-instruct

# Optional local port for Express
PORT=3000

# Optional: how many messages Alpha keeps per chat in Telegram
ALPHA_CHAT_HISTORY_LIMIT=24

# Optional: per HF request step timeout in milliseconds
ALPHA_REQUEST_TIMEOUT_MS=5000

# Optional: browser origins allowed to call /api/alpha
ALPHA_CORS_ORIGIN=*

# Optional webhook secrets for Vercel mode
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_WEBHOOK_SETUP_TOKEN=replace-with-random-secret
